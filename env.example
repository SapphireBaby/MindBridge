# MindBridge — Environment Variables
# Copy this file to .env and fill in your values
# Never commit your actual .env file to GitHub

# -----------------------------------------------
# ANTHROPIC
# -----------------------------------------------
# Your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# -----------------------------------------------
# MEDO / BAIDU (if self-hosting outside MeDo)
# -----------------------------------------------
# ERNIE API key — get one at https://cloud.baidu.com
ERNIE_API_KEY=your_ernie_api_key_here
ERNIE_SECRET_KEY=your_ernie_secret_key_here

# -----------------------------------------------
# APP CONFIG
# -----------------------------------------------
# Environment: development | production
NODE_ENV=development

# Port for local dev server (default: 3000)
PORT=3000

# Max conversation turns before auto-debrief trigger
MAX_TURNS=5
